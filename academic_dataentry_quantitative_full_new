<script>
// ============================================================
// DATA
// ============================================================
const CLASS_STUDENTS = {
  "Y1-A": ["Ye Yint Tayza Hman","Shoon La Woon Htet","Htun Lae Yi Mon","Lwin Aung Hein","Aung Bhone San","Htet Nay Bhone","Sian Vang Huai Kim","Thu Htet Htoo","Khant Su Thar","Lwin Khit","Htut Myat Aung","Myat Shwe Yee Thin","Kaung Khit Han","Linn Pyae Sone Aung","Sai Noon Wan Han","Ngwe Yati Moe","Khant Htet Zen"],
  "Y2-A": ["Zin Aung Hlaing","Phoo Pyae Heather","Shwe Sin Htet Aung","Thoon Thu San Aung","Linn Phone Khit","Khunn Thansin Han","Lin Thiri Hmue","Yuu Mi Khaing Lin","Yoon Htet Htet"]
};
const CLASS_SUBJECTS = {
  "Y1-A": ["English","Mathematics","Science","Social Studies","Myanmar","Wellbeing","ICT","Chinese"],
  "Y2-A": ["English","Mathematics","Science","Social Studies","Myanmar","Myanmar Social Studies","Wellbeing","ICT","Chinese"]
};

// Chinese removed from TEST_ONLY_SUBJECTS to follow standard 40/60 logic
const TEST_ONLY_SUBJECTS = []; 
const SUBJECT_COLORS = {
  "English":"#1d3557","Mathematics":"#8b3a0f","Science":"#1a6b2a","Social Studies":"#7b4f12",
  "Myanmar":"#8b1a4a","Myanmar Social Studies":"#5b2d8e","Wellbeing":"#0e6b6b","ICT":"#1a3d6b","Chinese":"#8b0000"
};

let subjectData = {}, currentClass = "Y1-A";

// ============================================================
// HELPERS
// ============================================================
function SK(s) { return s.replace(/\s+/g,"_").replace(/[^a-zA-Z0-9_]/g,""); }

function colLabel(id) {
  if (id.startsWith("cw-ut"))   return "Unit Test "    + id.replace("cw-ut","");
  if (id.startsWith("cw-test")) return "Test "         + id.replace("cw-test","");
  if (id.startsWith("cw-proj")) return "Project "      + id.replace("cw-proj","");
  if (id.startsWith("cw-pres")) return "Presentation " + id.replace("cw-pres","");
  return id;
}

function prefixGroup(id) {
  if (id.startsWith("cw-ut"))   return "cw-ut";
  if (id.startsWith("cw-test")) return "cw-test";
  if (id.startsWith("cw-proj")) return "cw-proj";
  if (id.startsWith("cw-pres")) return "cw-pres";
  return "other";
}

// ============================================================
// INIT / CLASS LOAD
// ============================================================
function loadClass() {
  currentClass = document.getElementById("classSelect").value;
  subjectData = {};
  CLASS_SUBJECTS[currentClass].forEach(s => {
    // All subjects now start with Unit Test by default
    subjectData[s] = { cwColumns: ["cw-ut1"] };
  });
  renderAllSubjects();
  updateSummary();
}

// ============================================================
// RENDER
// ============================================================
function renderAllSubjects() {
  const container = document.getElementById("subjectSections");
  container.innerHTML = "";
  CLASS_SUBJECTS[currentClass].forEach(s => renderSubject(s, container));
  attachSS();
}

function renderSubject(subject, container) {
  const isTestOnly = TEST_ONLY_SUBJECTS.includes(subject);
  const sd = subjectData[subject];
  const sk = SK(subject);
  const color = SUBJECT_COLORS[subject] || "#1d3557";
  const students = CLASS_STUDENTS[currentClass];

  const div = document.createElement("div");
  div.className = "subject-section";
  div.id = "sec_"+sk;

  // Standard subjects get all buttons
  let cwBtnsHtml = `<div class="cw-btns">
    <button class="btn-sm" onclick="addCW('${subject}','ut')">+ Unit Test</button>
    <button class="btn-sm" onclick="addCW('${subject}','proj')">+ Project</button>
    <button class="btn-sm" onclick="addCW('${subject}','pres')">+ Presentation</button>
  </div>`;

  let hdr1, hdr2Html, subjectTag;

  // Normal subjects: Exam 60% | CW 40%
  subjectTag = "40% CW + 60% Exam";
  const cwSubColsHtml = sd.cwColumns.map(id =>
    `<th id="cwcol_${sk}_${id}" data-role="cw-col" style="min-width:78px;">${colLabel(id)} <button class="delete-col-btn" onclick="delCW('${subject}','${id}')">×</button></th>`
  ).join("") + `<th data-role="cw-total" style="min-width:75px;">CW Total</th>`;
  
  hdr1 = `
    <tr>
      <th rowspan="2">Nr.</th>
      <th rowspan="2" style="min-width:155px;text-align:left;padding-left:8px;">Student Name</th>
      <th colspan="2" style="background:#fff0a0;">Term Exam 60%</th>
      <th id="cwHdr_${sk}" colspan="${sd.cwColumns.length+1}" style="background:#d6ebff;">Coursework 40%</th>
      <th colspan="2" style="background:#eaffea;">TOTAL (100%)</th>
    </tr>`;
  
  hdr2Html = `<tr>
    <th data-role="exam-score" style="min-width:78px;">Exam Score</th>
    <th data-role="exam-total" style="min-width:75px;">Exam Total</th>
    ${cwSubColsHtml}
    <th data-role="original-total" style="min-width:68px;">Original</th>
    <th data-role="rounded-total" style="min-width:68px;">Rounded</th>
  </tr>`;

  div.innerHTML = `
    <div class="subject-header" style="background:${color};">
      ${subject} <span class="subject-tag">${subjectTag}</span>
      ${cwBtnsHtml}
    </div>
    <div class="card">
      <div class="table-wrapper">
        <table id="tbl_${sk}">
          <thead>${hdr1}${hdr2Html}</thead>
          <tbody id="tbody_${sk}"></tbody>
        </table>
      </div>
    </div>`;

  container.appendChild(div);
  const tbody = div.querySelector(`#tbody_${sk}`);
  students.forEach((name, i) => buildRow(tbody, i+1, name, subject));
  recalc(subject);
}

function buildRow(tbody, nr, name, subject) {
  const sd = subjectData[subject];
  const tr = document.createElement("tr");
  tr.setAttribute("data-student", name);

  let html = `<td>${nr}</td><td class="label-col"><div class="cell-inner name-inner" contenteditable="false">${name}</div></td>`;

  // Normal: Exam first, then CW, then totals
  html += `<td class="exam-cell exam-score-cell"><div class="cell-inner" contenteditable="true" data-type="number"></div></td>`;
  html += `<td class="exam-total-cell"><span class="readonly-inner">0.00</span></td>`;
  sd.cwColumns.forEach(id => {
    html += `<td class="cw-cell" data-col="${id}"><div class="cell-inner" contenteditable="true" data-type="number"></div></td>`;
  });
  html += `<td class="cw-total-cell"><span class="readonly-inner">0.00</span></td>`;
  html += `<td class="total-cell final-total-cell"><span class="readonly-inner">0.00</span></td>`;
  html += `<td class="total-cell rounded-total-cell"><span class="readonly-inner">0</span></td>`;

  tr.innerHTML = html;
  tbody.appendChild(tr);
}

// ============================================================
// LOGIC CONTROLS
// ============================================================
function addCW(subject, type) {
  const sd = subjectData[subject];
  const prefix = "cw-" + type;
  const idx = sd.cwColumns.filter(id => id.startsWith(prefix)).length + 1;
  const colId = prefix + idx;
  const group = prefixGroup(colId);
  let insertAfterIdx = -1;
  sd.cwColumns.forEach((id, i) => { if (prefixGroup(id) === group) insertAfterIdx = i; });
  if (insertAfterIdx === -1) {
    const groupOrder = ["cw-ut","cw-test","cw-proj","cw-pres"];
    const myGroupPos = groupOrder.indexOf(group);
    for (let g = myGroupPos + 1; g < groupOrder.length; g++) {
      const firstOfNext = sd.cwColumns.findIndex(id => id.startsWith(groupOrder[g]));
      if (firstOfNext !== -1) { insertAfterIdx = firstOfNext - 1; break; }
    }
  }
  const arrayInsertPos = insertAfterIdx + 1;
  sd.cwColumns.splice(arrayInsertPos, 0, colId);

  const sk = SK(subject);
  const hdr2 = document.getElementById("tbl_"+sk).querySelector("thead tr:nth-child(2)");
  const cwTotalTh = hdr2.querySelector('th[data-role="cw-total"]');
  const afterId = insertAfterIdx >= 0 ? sd.cwColumns[insertAfterIdx] : null;
  const afterTh = afterId ? document.getElementById("cwcol_"+sk+"_"+afterId) : null;

  const newTh = document.createElement("th");
  newTh.id = "cwcol_"+sk+"_"+colId;
  newTh.setAttribute("data-role","cw-col");
  newTh.style.minWidth = "78px";
  newTh.innerHTML = `${colLabel(colId)} <button class="delete-col-btn" onclick="delCW('${subject}','${colId}')">×</button>`;

  if (afterTh && afterTh.nextSibling) hdr2.insertBefore(newTh, afterTh.nextSibling);
  else hdr2.insertBefore(newTh, cwTotalTh);

  const newHdrIdx = Array.from(hdr2.children).indexOf(newTh);
  document.querySelectorAll(`#tbody_${sk} tr`).forEach(row => {
    const td = document.createElement("td");
    td.className = "cw-cell";
    td.setAttribute("data-col", colId);
    td.innerHTML = `<div class="cell-inner" contenteditable="true" data-type="number"></div>`;
    const pos = newHdrIdx + 2;
    if (pos >= row.children.length) row.appendChild(td);
    else row.insertBefore(td, row.children[pos]);
  });
  updateCWSpan(subject);
  attachSS();
  recalc(subject);
}

function delCW(subject, colId) {
  const sd = subjectData[subject];
  sd.cwColumns = sd.cwColumns.filter(id => id !== colId);
  if (!sd.cwColumns.length) sd.cwColumns = ["cw-ut1"];
  const sk = SK(subject);
  document.getElementById("cwcol_"+sk+"_"+colId)?.remove();
  document.querySelectorAll(`#tbody_${sk} td[data-col="${colId}"]`).forEach(td => td.remove());
  updateCWSpan(subject);
  recalc(subject);
}

function updateCWSpan(subject) {
  const sk = SK(subject);
  const h = document.getElementById("cwHdr_"+sk);
  if (!h) return;
  h.colSpan = subjectData[subject].cwColumns.length + 1;
}

// ============================================================
// CALCULATION
// ============================================================
function getN(el) {
  if (!el) return 0;
  const v = parseFloat(el.textContent.trim());
  return isNaN(v) ? 0 : Math.min(100, Math.max(0, v));
}

function recalc(subject) {
  const sk = SK(subject);
  document.querySelectorAll(`#tbody_${sk} tr`).forEach(row => {
    // Standard logic applied to all subjects
    const examRaw = getN(row.querySelector(".exam-score-cell .cell-inner"));
    const examPct = (examRaw / 100) * 60;
    let ut = [], other = [];
    row.querySelectorAll("td[data-col]").forEach(td => {
      const id = td.getAttribute("data-col");
      const v = getN(td.querySelector(".cell-inner"));
      if (id.startsWith("cw-ut")) ut.push(v);
      else other.push(v);
    });
    const utA = ut.length ? ut.reduce((a,b)=>a+b,0)/ut.length : 0;
    const otA = other.length ? other.reduce((a,b)=>a+b,0)/other.length : 0;
    let cwPct = 0;
    if (ut.length && other.length)   cwPct = (utA/100)*25 + (otA/100)*15;
    else if (ut.length)               cwPct = (utA/100)*40;
    else if (other.length)            cwPct = (otA/100)*40;
    
    const total = examPct + cwPct;
    const set = (q, v) => { const e = row.querySelector(q); if (e) e.textContent = v; };
    set(".exam-total-cell .readonly-inner",  examPct.toFixed(2));
    set(".cw-total-cell .readonly-inner",    cwPct.toFixed(2));
    set(".final-total-cell .readonly-inner", total.toFixed(2));
    set(".rounded-total-cell .readonly-inner", Math.round(total));
  });
  updateSummary();
}

function getScores() {
  const result = {};
  CLASS_STUDENTS[currentClass].forEach(n => { result[n] = {}; });
  CLASS_SUBJECTS[currentClass].forEach(subject => {
    const sk = SK(subject);
    document.querySelectorAll(`#tbody_${sk} tr`).forEach(row => {
      const name = row.querySelector(".name-inner")?.textContent.trim();
      if (!name || !result[name]) return;
      const cw = parseFloat(row.querySelector(".cw-total-cell .readonly-inner")?.textContent) || 0;
      const exam = parseFloat(row.querySelector(".exam-total-cell .readonly-inner")?.textContent) || 0;
      const total = parseInt(row.querySelector(".rounded-total-cell .readonly-inner")?.textContent) || 0;
      result[name][subject] = { exam, cw, total };
    });
  });
  return result;
}

// ============================================================
// SUMMARY & UI BEHAVIORS
// ============================================================
function updateSummary() {
  const subjects = CLASS_SUBJECTS[currentClass];
  const students = CLASS_STUDENTS[currentClass];
  const scores = getScores();

  let hdr1 = `<th class="sum-td-subject" rowspan="2">Subject</th>`;
  students.forEach(s => { hdr1 += `<th class="sum-th-student" colspan="3">${s}</th>`; });

  let hdr2 = "";
  students.forEach(() => {
    hdr2 += `<th class="sum-th-type sum-th-exam">Exam (60%)</th>`;
    hdr2 += `<th class="sum-th-type sum-th-cw">CW (40%)</th>`;
    hdr2 += `<th class="sum-th-type sum-th-total">Total</th>`;
  });

  let rows = "";
  subjects.forEach(subject => {
    let row = `<td class="sum-td-subject"><b>${subject}</b></td>`;
    students.forEach(s => {
      const d = (scores[s] || {})[subject] || { exam: 0, cw: 0, total: 0 };
      row += `<td class="sum-td-exam">${d.exam.toFixed(2)}</td>`;
      row += `<td class="sum-td-cw">${d.cw.toFixed(2)}</td>`;
      row += `<td class="sum-td-total">${d.total}</td>`;
    });
    rows += `<tr>${row}</tr>`;
  });

  document.getElementById("summaryContainer").innerHTML = `
    <table class="summary-table">
      <thead><tr>${hdr1}</tr><tr>${hdr2}</tr></thead>
      <tbody>${rows}</tbody>
    </table>`;
}

// Spreadsheet logic & Excel handling
let selCell = null, selStart = null, selEnd = null;
function attachSS() {
  document.querySelectorAll("tbody td").forEach(td => {
    if (td._ss) return; td._ss = true;
    td.addEventListener("mousedown", e => {
      const inner = td.querySelector(".cell-inner[contenteditable='true']");
      if (!inner) return;
      if (e.shiftKey && selStart) { selEnd = coords(td); highlightRange(selStart, selEnd); e.preventDefault(); }
      else selCell2(td);
    });
